{
  "geode": "5.4.1",
  "gd": "2.2081",

  "id": "crxptos.replay_saver",
  "name": "Replay Saver",
  "version": "1.0.0",
  "developer": "Crxptos",

  "description": "Automatically saves replays and exports them as MP4.",

  "platforms": ["android"],

  "links": {
    "source": "https://github.com/Crxptos/Replay-Saver"
  },

  "resources": {
    "files": [
      "logo.png"
    ]
  },

  "dependencies": [
    {
      "id": "geode.node-ids",
      "version": ">=1.23.0"
    },
    {
      "id": "eclipse.ffmpeg-api",
      "version": ">=2.0.0"
    }
  ],

  "settings": {
    "auto-save": {
      "type": "bool",
      "name": "Auto Save Replay",
      "description": "Automatically saves replay when a level is completed.",
      "default": true
    },
    "auto-export": {
      "type": "bool",
      "name": "Auto Export MP4",
      "description": "Automatically exports replay as MP4.",
      "default": false
    },
    "save-path": {
      "type": "file",
      "name": "Save Location",
      "description": "Where replays are saved.",
      "default": "geode/mods/crxptos.replay_saver/savedReplays"
    },
    "fps": {
      "type": "int",
      "name": "FPS",
      "description": "Frames per second for video export.",
      "default": 60,
      "min": 30,
      "max": 240
    },
    "quality": {
      "type": "enum",
      "name": "Export Quality",
      "description": "Video quality preset.",
      "default": "1080p",
      "options": ["720p", "1080p", "1440p"]
    },
    "audio": {
      "type": "bool",
      "name": "Record Audio",
      "description": "Include audio in exported video.",
      "default": true
    },
    "notifications": {
      "type": "bool",
      "name": "Show Notifications",
      "description": "Show messages when saving replays.",
      "default": true
    },
    "manual-button": {
      "type": "bool",
      "name": "Show Save Button",
      "description": "Adds a Save Replay button on level complete screen.",
      "default": true
    },
    "ghost": {
      "type": "bool",
      "name": "Enable Ghost Replay",
      "description": "Saves ghost replay data.",
      "default": false
    },
    "debug": {
      "type": "bool",
      "name": "Debug Mode",
      "description": "Enable debug logging.",
      "default": false
    }
  }
}
