{
  "geode": ">=5.0.0",
  "gd": "2.2081",

  "id": "crxptos.replay_saver",
  "name": "Replay Saver",
  "version": "1.0.1",
  "developer": "crxptos",

  "description": "Automatically records and saves replays with optional MP4 export.",
  "repository": "https://github.com/Crxptos/replay-saver",

  "tags": [
    "utility",
    "replay",
    "recording"
  ],

  "dependencies": [
    {
      "id": "eclipse.ffmpeg-api",
      "version": ">=2.0.0"
    }
  ],

  "settings": {
    "auto-export-mp4": {
      "type": "bool",
      "name": "Auto Export MP4",
      "description": "Automatically export replay as MP4 after completing a level.",
      "default": true
    },
    "save-replay-data": {
      "type": "bool",
      "name": "Save Replay Data",
      "description": "Save replay data files.",
      "default": true
    }
  }
}
